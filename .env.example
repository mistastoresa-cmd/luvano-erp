# Neon pooled connection string. Not required to run tests (tests use in-memory pglite).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Placeholders for the Salla connector — unused in this phase (no live webhook route yet),
# present so the connector adapter's types match the real env shape when wired up later.
SALLA_CLIENT_ID=your_salla_client_id
SALLA_CLIENT_SECRET=your_salla_client_secret
SALLA_WEBHOOK_SECRET=your_salla_webhook_secret
