# Neon pooled connection string. Not required to run tests (tests use in-memory pglite).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Better Auth (lib/auth/server.ts). Without a real secret, Better Auth logs a
# BetterAuthError warning and falls back to an insecure default — fine for
# `next build`'s static analysis pass, NOT fine for anything actually
# reachable. Generate with `npx @better-auth/cli secret`.
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=http://localhost:3000

# Placeholders for the Salla connector — unused in this phase (no live webhook route yet),
# present so the connector adapter's types match the real env shape when wired up later.
SALLA_CLIENT_ID=your_salla_client_id
SALLA_CLIENT_SECRET=your_salla_client_secret
SALLA_WEBHOOK_SECRET=your_salla_webhook_secret
